            void DropCurrentWeaponNoGravity()
            {
                game::playerState_s* ps = game::GetLocalPlayerState();
                if (!ps) return;
                unsigned int weapIdx = ps->currentWeapon;
                if (!weapIdx) return;

                game::gentity_s* ent = &game::g_entities[0];
                if (!ent->client) return;

                DWORD* wd = GetWeaponDef(weapIdx);
                if (!wd || *(int*)((char*)wd + 56) == 3) return;

                unsigned char    weaponModel = BG_GetWeaponModel_fn(&ent->client->ps, weapIdx);
                int              itemIndex = (int)weaponModel * 1400 + (int)weapIdx;
                game::gentity_s* dropped = LaunchItem_fn(itemIndex, *(int*)((char*)ent));
                if (!dropped) return;

                TransferPlayerAmmoToWeaponEntity_fn(ent, dropped, weapIdx);
                G_TakePlayerWeapon_fn(&ent->client->ps, weapIdx);

                float origin[3] = { ps->origin[0], ps->origin[1], ps->origin[2] + 20.f };
                G_SetOrigin_fn(dropped, origin);


                dropped->spawnflags |= 1; 
                SV_LinkEntity_fn(dropped);
            }
